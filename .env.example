# Mapbox — server-side token (geocoding, isochrone APIs)
MAPBOX_ACCESS_TOKEN=

# Mapbox — client-side token (map rendering in browser)
NEXT_PUBLIC_MAPBOX_TOKEN=

# US Census Bureau API key
CENSUS_API_KEY=

# PostgreSQL connection string (Neon/Vercel Postgres)
DATABASE_URL=

# Anthropic API key (for AI narrative generation)
ANTHROPIC_API_KEY=

# Base URL for absolute OG image URLs (e.g., https://locale.leroi.ai)
# Falls back to VERCEL_URL on Vercel, or http://localhost:3000 locally
NEXT_PUBLIC_BASE_URL=

# Max new report generations per UTC day (global across all IPs). Set to 0 to disable.
# Default: 100
MAX_DAILY_REPORTS=100
